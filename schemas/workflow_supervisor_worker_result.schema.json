{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness workflow supervisor worker result",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "node_id",
    "skill",
    "attempt",
    "status",
    "exit_code",
    "started_at",
    "finished_at",
    "summary",
    "artifact_refs",
    "gate_ledger",
    "postcondition_claims",
    "interrupt_request",
    "observed_writes",
    "stdout_ref",
    "stderr_ref",
    "contract_violations",
    "worker_warnings"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "pattern": "^sup_[A-Za-z0-9_:-]+$" },
    "node_id": { "type": "string", "minLength": 1 },
    "skill": { "type": "string", "minLength": 1 },
    "attempt": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["success", "failed", "interrupt_requested", "not_run"]
    },
    "exit_code": { "type": ["integer", "null"] },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "summary": { "type": "string" },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gate_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "result", "reason", "artifacts"],
        "properties": {
          "command": { "type": "string" },
          "result": {
            "type": "string",
            "enum": ["PASS", "FAIL", "NOT_RUN"]
          },
          "reason": { "type": "string" },
          "artifacts": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "postcondition_claims": {
      "type": "array",
      "items": { "type": "object" }
    },
    "interrupt_request": { "type": ["object", "null"] },
    "observed_writes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stdout_ref": { "type": ["string", "null"] },
    "stderr_ref": { "type": ["string", "null"] },
    "contract_violations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "worker_warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
