{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iteration Log",
  "description": "Strict v2 structured iteration tracking for research experiments.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "baseline_metrics",
    "iterations",
    "best_iteration"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2"
    },
    "project": {
      "type": "string"
    },
    "evaluation_protocol": {
      "type": ["object", "null"],
      "properties": {
        "primary_metric": {
          "type": ["string", "object", "null"]
        },
        "tracked_metrics": {
          "type": "array",
          "items": {
            "type": ["object", "string"]
          }
        },
        "comparison_rule": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "baseline_metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "iterations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "date",
          "hypothesis",
          "changes_summary",
          "config_diff",
          "status",
          "action_state",
          "implementation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^iter\\d+[a-z]?(_no_[a-z_]+)?$"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "hypothesis": {
            "type": "string"
          },
          "changes_summary": {
            "type": "string"
          },
          "config_diff": {
            "type": "object"
          },
          "git_commit": {
            "type": ["string", "null"]
          },
          "git_message": {
            "type": ["string", "null"]
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "coding",
              "ready_to_run",
              "running",
              "ready_to_eval",
              "needs_debug",
              "needs_more_evidence",
              "candidate_for_promotion",
              "promoting",
              "completed",
              "abandoned"
            ]
          },
          "action_state": {
            "$ref": "#/definitions/action_state"
          },
          "implementation": {
            "$ref": "#/definitions/implementation"
          },
          "metrics": {
            "type": "object",
            "additionalProperties": {
              "type": ["number", "string", "null"]
            }
          },
          "training_trace": {
            "type": ["object", "null"],
            "additionalProperties": {
              "type": ["number", "string", "null"]
            }
          },
          "screening": {
            "type": ["object", "null"],
            "properties": {
              "recommended": {
                "type": "boolean"
              },
              "status": {
                "type": "string",
                "enum": ["passed", "failed", "skipped"]
              },
              "metrics": {
                "type": "object",
                "additionalProperties": {
                  "type": ["number", "string", "null"]
                }
              },
              "run_manifest": {
                "type": ["object", "null"],
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          },
          "full_run": {
            "type": ["object", "null"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["completed", "recoverable_failed", "failed"]
              },
              "resume_mode": {
                "type": ["string", "null"]
              },
              "metrics": {
                "type": "object",
                "additionalProperties": {
                  "type": ["number", "string", "null"]
                }
              },
              "error": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": true
          },
          "decision": {
            "type": ["string", "null"],
            "enum": ["NEXT_ROUND", "CONTINUE", "DEBUG", "PIVOT", "ABORT", null]
          },
          "lessons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "lesson_candidates": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "lesson_promotion_status": {
            "type": ["string", "null"],
            "enum": ["none", "candidate", "accepted", "rejected", null]
          },
          "evidence_chain": {
            "type": ["string", "null"]
          },
          "light_evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "codex_review": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              },
              {
                "type": "null"
              }
            ]
          },
          "codex_review_detail": {
            "type": ["object", "null"],
            "additionalProperties": true
          },
          "run_manifest": {
            "type": ["object", "null"],
            "additionalProperties": true
          },
          "parent_iteration": {
            "type": ["string", "null"]
          },
          "ablation_component": {
            "type": ["string", "null"]
          },
          "ablation_summary": {
            "type": ["object", "null"],
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "best_iteration": {
      "type": ["string", "null"]
    }
  },
  "definitions": {
    "next_action": {
      "type": "string",
      "enum": [
        "plan",
        "code",
        "run_screening",
        "run_full",
        "eval",
        "debug",
        "compare",
        "ablate",
        "register",
        "promote",
        "discard",
        "stop"
      ]
    },
    "action_state": {
      "type": "object",
      "required": ["next_action", "last_action", "reason", "blocked_by"],
      "properties": {
        "next_action": {
          "$ref": "#/definitions/next_action"
        },
        "last_action": {
          "anyOf": [
            {
              "$ref": "#/definitions/next_action"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "type": "string"
        },
        "blocked_by": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "implementation": {
      "type": "object",
      "required": [
        "scope",
        "code_manifest_path",
        "touched_paths",
        "stable_api_changed",
        "delegated_build_run_id",
        "promotion"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "config_only",
            "run_local_code",
            "stable_candidate",
            "delegated_build"
          ]
        },
        "code_manifest_path": {
          "type": ["string", "null"]
        },
        "touched_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stable_api_changed": {
          "type": "boolean"
        },
        "delegated_build_run_id": {
          "type": ["string", "null"]
        },
        "promotion": {
          "type": "object",
          "required": ["status", "plan_path"],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "not_applicable",
                "not_ready",
                "candidate",
                "promoting",
                "promoted",
                "rejected"
              ]
            },
            "plan_path": {
              "type": ["string", "null"]
            },
            "promoted_commit": {
              "type": ["string", "null"]
            },
            "risk": {
              "type": ["string", "null"],
              "enum": ["low", "medium", "high", null]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
