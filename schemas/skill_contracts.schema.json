{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness skill contracts",
  "type": "object",
  "required": ["schema_version", "contracts"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "skill",
          "triggers",
          "required_read_set",
          "required_actions",
          "constraints",
          "gate_ledger_required_when",
          "write_scope",
          "artifact_outputs"
        ],
        "properties": {
          "skill": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "triggers": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "required_read_set": {
            "type": "object",
            "required": ["harness", "skill", "project_when_present", "project_optional"],
            "properties": {
              "harness": {
                "type": "array",
                "items": { "type": "string" }
              },
              "skill": {
                "type": "array",
                "items": { "type": "string" }
              },
              "project_when_present": {
                "type": "array",
                "items": { "type": "string" }
              },
              "project_optional": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "required_actions": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "forbidden_actions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Deprecated mirror for legacy hook/tests. New policy reads constraints[]."
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "kind",
                "tier",
                "enforcement",
                "exception_policy"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9_.-]+$"
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "forbidden_action",
                    "required_action",
                    "boundary",
                    "gate",
                    "notice"
                  ]
                },
                "tier": {
                  "type": "string",
                  "enum": [
                    "hard_invariant",
                    "ownership_boundary",
                    "workflow_default",
                    "advisory"
                  ]
                },
                "enforcement": {
                  "type": "string",
                  "enum": ["block", "notice", "ledger"]
                },
                "exception_policy": {
                  "type": "string",
                  "enum": [
                    "never",
                    "owner_delegation_required",
                    "human_approval_required",
                    "overlay_allowed",
                    "not_required"
                  ]
                },
                "notes": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "minItems": 1
          },
          "gate_ledger_required_when": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "sensitive_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "context_budget": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                { "type": "integer", "minimum": 1 },
                { "type": "string", "minLength": 1 },
                { "type": "boolean" }
              ]
            }
          },
          "write_scope": {
            "type": "object",
            "required": ["allowed_paths"],
            "properties": {
              "allowed_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "artifact_outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "paths",
                "owner",
                "is_final",
                "requires_tool"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "current_doc",
                    "approved_contract",
                    "fact_doc",
                    "conclusion_evidence",
                    "generated_view",
                    "canonical_state",
                    "tool_trace",
                    "review_trace",
                    "implementation",
                    "guidance",
                    "release_package",
                    "legacy_compat",
                    "operational_scope"
                  ]
                },
                "paths": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "owner": { "type": "string" },
                "is_final": { "type": "boolean" },
                "requires_tool": { "type": "boolean" },
                "replacement": { "type": "string" },
                "notes": { "type": "string" }
              },
              "additionalProperties": false
            },
            "minItems": 1
          },
          "default_validation_profile": {
            "type": "string",
            "enum": ["slice", "guardrail", "docs", "experiment", "release"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
