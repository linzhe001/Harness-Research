{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Docs Site Manifest",
  "type": "object",
  "required": ["schema_version", "generated_at", "source_root", "output_root", "pages", "navigation"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "source_root": { "type": "string" },
    "output_root": { "type": "string" },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_id", "doc_kind", "title", "source_path", "html_path"],
        "properties": {
          "doc_id": { "type": "string" },
          "doc_kind": { "type": "string" },
          "title": { "type": "string" },
          "source_path": { "type": "string" },
          "html_path": { "type": "string" },
          "status": { "type": ["string", "null"] },
          "evidence_chain_path": { "type": ["string", "null"] },
          "preview_index_path": { "type": ["string", "null"] },
          "related_pages": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "navigation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "pages"],
        "properties": {
          "label": { "type": "string" },
          "pages": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
